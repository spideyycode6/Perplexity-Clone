# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/perplexity

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# JWT Authentication
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=7d

# Email (Gmail) — pick ONE approach:

# A) App Password (simplest): Google Account → Security → 2-Step Verification → App passwords
# Either name works (spaces in the 16-char password are optional):
GMAIL_APP_PASSWORD=your_16_char_app_password
# GOOGLE_APP_PASSWORD=your_16_char_app_password
GOOGLE_USER=your_google_email@gmail.com

# B) OAuth2 (optional): refresh token from OAuth Playground with Gmail scope
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_SECRET=your_google_secret
# GOOGLE_REFRESH_TOKEN=your_google_refresh_token
# GOOGLE_USER=your_google_email@gmail.com

# Public URL of this API (used in verification links). Defaults to http://localhost:PORT
# PUBLIC_API_URL=http://localhost:3000

# AI API Keys
GEMINI_API_KEY=your_gemini_api_key
MISTRAL_API_KEY=your_mistral_api_key
TAVILY_API_KEY=your_tavily_api_key
