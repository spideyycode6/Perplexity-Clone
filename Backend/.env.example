# Server
PORT=3000
NODE_ENV=production

# MongoDB (Atlas: allow 0.0.0.0/0 or Render outbound IPs)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# CORS — comma-separated. Local dev + your production URL, e.g.:
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-app.onrender.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT
JWT_SECRET=use_a_long_random_string
JWT_EXPIRY=7d

# Email — pick ONE (Render: Resend avoids SMTP blocks; Gmail tries app password then OAuth2)

# 0) Resend (HTTPS) — https://resend.com
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=onboarding@resend.dev

# A) Gmail app password (16 chars, not your normal password)
GMAIL_APP_PASSWORD=your_16_char_app_password
GOOGLE_USER=your_email@gmail.com

# B) Gmail OAuth2 (optional fallback if A fails)
# GOOGLE_CLIENT_ID=
# GOOGLE_SECRET=
# GOOGLE_REFRESH_TOKEN=

# Public site URL — required for correct links in verification emails on deploy
PUBLIC_API_URL=https://your-app.onrender.com

# AI
GEMINI_API_KEY=
MISTRAL_API_KEY=
TAVILY_API_KEY=
